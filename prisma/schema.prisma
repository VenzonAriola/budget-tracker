generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- Auth.js (NextAuth) required models ----------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String? // for credentials login (hashed)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]

  bankAccounts  BankAccount[]
  categories    Category[]
  transactions  Transaction[]
  budgets       Budget[]
  savingsGoals  SavingsGoal[]
  bills         Bill[]
  notifications Notification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Domain models ----------

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT_CARD
  CASH
  INVESTMENT
  OTHER
}

model BankAccount {
  id        String      @id @default(cuid())
  userId    String
  name      String
  type      AccountType @default(CHECKING)
  color     String      @default("#1FAA75")
  balance   Decimal     @default(0) @db.Decimal(12, 2)
  currency  String      @default("USD")
  isArchived Boolean    @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

model Category {
  id        String          @id @default(cuid())
  userId    String
  name      String
  type      TransactionType @default(EXPENSE)
  icon      String          @default("Tag")
  color     String          @default("#6C63F5")
  monthlyLimit Decimal?     @db.Decimal(12, 2)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]

  @@unique([userId, name])
  @@index([userId])
}

model Transaction {
  id          String          @id @default(cuid())
  userId      String
  accountId   String
  categoryId  String?
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  description String?
  merchant    String?
  date        DateTime        @default(now())
  receiptUrl  String?
  tags        String[]        @default([])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  BankAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([accountId])
  @@index([categoryId])
}

model Budget {
  id         String   @id @default(cuid())
  userId     String
  categoryId String
  amount     Decimal  @db.Decimal(12, 2)
  month      Int // 1-12
  year       Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, month, year])
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

model SavingsGoal {
  id            String     @id @default(cuid())
  userId        String
  name          String
  targetAmount  Decimal    @db.Decimal(12, 2)
  currentAmount Decimal    @default(0) @db.Decimal(12, 2)
  targetDate    DateTime?
  status        GoalStatus @default(ACTIVE)
  color         String     @default("#6C63F5")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum BillFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

model Bill {
  id          String        @id @default(cuid())
  userId      String
  name        String
  amount      Decimal       @db.Decimal(12, 2)
  dueDate     DateTime
  frequency   BillFrequency @default(MONTHLY)
  isPaid      Boolean       @default(false)
  autoRemind  Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum NotificationType {
  BILL_DUE
  BUDGET_EXCEEDED
  GOAL_MILESTONE
  GENERAL
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(GENERAL)
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}
